@model parcial.Models.CursoFormViewModel

@{
    ViewData["Title"] = "Crear curso";
}

<h1 class="mb-3">Crear curso</h1>

<form asp-action="CreateCurso" method="post" class="card card-body">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Codigo" class="form-label"></label>
            <input asp-for="Codigo" class="form-control" />
            <span asp-validation-for="Codigo" class="text-danger"></span>
        </div>

        <div class="col-md-8">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Creditos" class="form-label"></label>
            <input asp-for="Creditos" class="form-control" min="1" type="number" />
            <span asp-validation-for="Creditos" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="CupoMaximo" class="form-label"></label>
            <input asp-for="CupoMaximo" class="form-control" min="1" type="number" />
            <span asp-validation-for="CupoMaximo" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="HorarioInicio" class="form-label"></label>
            <input asp-for="HorarioInicio" class="form-control" type="time" />
            <span asp-validation-for="HorarioInicio" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="HorarioFin" class="form-label"></label>
            <input asp-for="HorarioFin" class="form-control" type="time" />
            <span asp-validation-for="HorarioFin" class="text-danger"></span>
        </div>

        <div class="col-12 form-check mt-2 ms-1">
            <input asp-for="Activo" class="form-check-input" />
            <label asp-for="Activo" class="form-check-label"></label>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver al panel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
